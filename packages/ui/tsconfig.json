{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    // 仅产出 d.ts；JS 由 vite + vite-plugin-solid 编译（正确处理 Solid JSX 转换）
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true
  },
  "include": ["src/**/*"]
}
